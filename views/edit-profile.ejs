<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upravit profil</title>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body>
    <%- include('partials/header') %>
    <div class="login-page">
        <div class="login-card">
            <% if (locals.message) { %>
                <div class="message <%= locals.type %>"><%= locals.message %></div>
            <% } %>
            <h1>Upravit profil</h1>
            <form action="/profile" method="post" class="login-form">
                <div class="form-group">
                    <label for="name">Jméno:</label>
                    <input type="text" id="name" name="name" value="<%= user.name %>" required>
                </div>

                <div class="form-group">
                    <label for="surname">Příjmení:</label>
                    <input type="text" id="surname" name="surname" value="<%= user.surname %>" required>
                </div>

                <div class="form-group">
                    <label for="username">E-mail:</label>
                    <input type="email" id="username" name="username" value="<%= user.username %>" disabled>
                </div>
                <hr>
                <p>Nechte pole hesla prázdné, pokud chcete zachovat současné heslo.</p>
                <div class="form-group">
                    <label for="oldPassword">Aktuální heslo:</label>
                    <input type="password" id="oldPassword" name="oldPassword" autocomplete="password">
                </div>
                <div class="form-group">
                    <label for="password">Nové heslo:</label>
                    <input type="password" id="password" name="password" autocomplete="new-password">
                </div>

                <div class="form-group">
                    <label for="password2">Potvrdit heslo:</label>
                    <input type="password" id="password2" name="password2" autocomplete="new-password">
                </div>

                <button type="submit">Uložit změny</button>
            </form>
        </div>
    </div>
</body>
</html>
