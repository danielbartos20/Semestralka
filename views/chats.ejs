<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moje chaty</title>
    <style>
        body { font-family: sans-serif; margin: 2em; }
        form { display: flex; gap: 10px; margin-bottom: 20px; }
        input[type="text"] { padding: 8px; border: 1px solid #ccc; border-radius: 4px; flex-grow: 1; max-width: 300px; }
        button { padding: 10px 15px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; }
        button:hover { background-color: #0056b3; }
        .message { margin-top: 1em; margin-bottom: 1em; padding: 10px; border-radius: 4px; max-width: 400px; }
        .success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .error { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        ul { list-style-type: none; padding: 0; max-width: 400px; }
        li { background: #f4f4f4; margin-bottom: 5px; padding: 10px; border-radius: 4px; display: flex; justify-content: space-between; align-items: center;}
        nav { margin-bottom: 20px; }
        nav a { text-decoration: none; color: #007bff; font-weight: bold; }
    </style>
</head>
<body>
    <nav><a href="/">&larr; Zpět na hlavní stránku</a></nav>
    
    <% if (locals.message) { %>
        <div class="message <%= locals.type %>"><%= locals.message %></div>
    <% } %>

    <h1>Seznam chatů</h1>

    <form action="/chats" method="post">
        <input type="text" name="name" placeholder="Název nové místnosti..." required>
        <button type="submit">Vytvořit chat</button>
    </form>

    <ul>
        <% locals.chats.forEach(function(chat) { %>
            <li><strong><a href="/chat/<%= chat.id %>"><%= chat.name %></strong></a></li>
        <% }); %>
    </ul>
</body>
</html>