<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WattsUp</title>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body>
    <%- include('partials/header') %>
    <% if (locals.message) { %>
        <div class="message <%= locals.type %>"><%= locals.message %></div>
    <% } %>

    <% if (locals.user) { %>
        <h1>Vítejte, <%= user.name %>!</h1>
    <% } else { %>
        <p>Pro vstup do aplikace se musíte přihlásit.</p>
        <nav><a href="/login">Přihlášení</a> | <a href="/register">Registrace</a></nav>
    <% } %>
</body>
</html>